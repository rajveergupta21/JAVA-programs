public class Area {
    // Area of Square
    void area(int side) {
        System.out.println("The area of the square: " + (side * side));
    }

    // Area of Rectangle
    void area(int len, int bre) {
        System.out.println("The area of the rectangle: " + (len * bre));
    }

    public static void main(String[] args) {
        Area a = new Area();
        a.area(5);
        a.area(5, 6);
    }
}
